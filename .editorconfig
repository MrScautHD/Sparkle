root = true

########################################
# Global settings
########################################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

# IMPORTANT: keep indentation-only lines
trim_trailing_whitespace = false

########################################
# C# files
########################################
[*.cs]

########################################
# Indentation
########################################
indent_style = space
indent_size = 4
tab_width = 4

########################################
# Braces & Newlines (your hybrid style)
########################################

# Opening brace on same line
csharp_new_line_before_open_brace = none

# These go on next line
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

########################################
# Spacing
########################################
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_after_comma = true

csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_parameter_list_parentheses = false

########################################
# this. qualification
########################################
dotnet_style_qualification_for_field = true:suggestion
dotnet_style_qualification_for_property = true:suggestion
dotnet_style_qualification_for_method = true:suggestion
dotnet_style_qualification_for_event = true:suggestion

########################################
# var usage (prefer explicit types)
########################################
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = false:suggestion

########################################
# Braces preference
########################################
csharp_prefer_braces = true:suggestion

########################################
# Using directives
########################################
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:suggestion

########################################
# Naming rules
########################################

# Private fields: _camelCase
dotnet_naming_rule.private_fields_should_be_camel_case.severity = suggestion
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_with_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_case_with_underscore.capitalization = camel_case
dotnet_naming_style.camel_case_with_underscore.required_prefix = _

# Public members: PascalCase
dotnet_naming_rule.public_members_pascal_case.severity = suggestion
dotnet_naming_rule.public_members_pascal_case.symbols = public_members
dotnet_naming_rule.public_members_pascal_case.style = pascal_case_style

dotnet_naming_symbols.public_members.applicable_kinds = property,method,field,event
dotnet_naming_symbols.public_members.applicable_accessibilities = public

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

########################################
# Blank lines (preserve your spacing)
########################################

# Allow blank/indented lines
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = true

########################################
# Rider / ReSharper specific
########################################

# Brace style
resharper_brace_style = end_of_line

# else/catch/finally on new line
resharper_csharp_place_else_on_new_line = true
resharper_csharp_place_catch_on_new_line = true
resharper_csharp_place_finally_on_new_line = true

# Preserve blank lines instead of collapsing them
resharper_csharp_blank_lines_around_field = 1
resharper_csharp_blank_lines_around_property = 1
resharper_csharp_blank_lines_around_method = 1
resharper_csharp_blank_lines_around_type = 1

resharper_csharp_blank_lines_around_statements = 1
resharper_csharp_keep_blank_lines_in_code = 1
resharper_keep_blank_lines_in_declarations = 1

# var usage
resharper_csharp_use_var_when_evident = false
resharper_csharp_use_var = false