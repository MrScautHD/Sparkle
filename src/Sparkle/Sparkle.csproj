<Project Sdk="Microsoft.NET.Sdk">
    
    <!-- Project -->
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <NoWarn>$(NoWarn);CS8618</NoWarn>
        <LangVersion>14</LangVersion>
    </PropertyGroup>
    
    <!-- Nuget -->
    <PropertyGroup>
        <Title>Sparkle</Title>
        <Authors>MrScautHD</Authors>
        <Version>5.0.2</Version>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);1591</NoWarn>
        <Description>A fast, Cross-platform .NET 10 C# 14 game engine.</Description>
        <PackageProjectUrl>https://mrscauthd.github.io/Sparkle/</PackageProjectUrl>
        <PackageLicenseUrl>https://github.com/MrScautHD/Sparkle/blob/main/LICENSE</PackageLicenseUrl>
        <RepositoryUrl>https://github.com/MrScautHD/Sparkle</RepositoryUrl>
        <PackageTags>Renderer, Game-Engine, Direct3D, Vulkan, Metal, OpenGL, OpenGL-ES, Net10, C#14, 2D, 3D, Fast, Physics, XNA, Cross-platform, Audio</PackageTags>
        <PackageIcon>icon.png</PackageIcon>
    </PropertyGroup>
    
    <!-- Libraries -->
    <ItemGroup>
        <PackageReference Include="Bliss" Version="1.5.3" GeneratePathProperty="true" />
        <PackageReference Include="HughPH.Box2D" Version="2026.4.30.141" />
        <PackageReference Include="Jitter2" Version="2.8.5" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />
    </ItemGroup>
    
    <!-- Icon -->
    <ItemGroup>
        <None Include="content\sparkle\images\icon.png" Pack="true" PackagePath="" />
    </ItemGroup>
    
    <!-- Sparkle Content -->
    <ItemGroup>
        <Content Include="content/**/*" Pack="true">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <PackageCopyToOutput>true</PackageCopyToOutput>
        </Content>
    </ItemGroup>

    <!-- Inject Bliss content into the generated Sparkle .nupkg -->
    <Target Name="InjectBlissContentIntoPackage" AfterTargets="Pack">
        <PropertyGroup>
            <Nupkg Condition="'$(PackageOutputPath)' != ''">$(PackageOutputPath)/$(PackageId).$(PackageVersion).nupkg</Nupkg>
            <Nupkg Condition="'$(PackageOutputPath)' == ''">$(OutputPath)$(PackageId).$(PackageVersion).nupkg</Nupkg>
            <Tmp>$(IntermediateOutputPath)package-repack</Tmp>
            <BlissContent>$(PkgBliss)/content/content/bliss</BlissContent>
            <SparkleTargets>$(Tmp)/buildTransitive/Sparkle.targets</SparkleTargets>
        </PropertyGroup>

        <Error Condition="'$(PkgBliss)' == ''"
               Text="PkgBliss is empty. Keep GeneratePathProperty='true' on the Bliss PackageReference and run dotnet restore." />

        <Error Condition="!Exists('$(BlissContent)')"
               Text="Bliss content folder not found: $(BlissContent)" />

        <RemoveDir Directories="$(Tmp)" />
        <MakeDir Directories="$(Tmp)" />

        <Unzip SourceFiles="$(Nupkg)"
               DestinationFolder="$(Tmp)"
               OverwriteReadOnlyFiles="true" />

        <ItemGroup>
            <BlissFiles Include="$(BlissContent)/**/*" />
        </ItemGroup>

        <Copy SourceFiles="@(BlissFiles)"
              DestinationFiles="@(BlissFiles->'$(Tmp)/content/content/bliss/%(RecursiveDir)%(Filename)%(Extension)')" />

        <MakeDir Directories="$(Tmp)/buildTransitive" />

        <ItemGroup>
            <SparkleTargetsLines Include="&lt;Project&gt;" />
            <SparkleTargetsLines Include="  &lt;ItemGroup&gt;" />
            <SparkleTargetsLines Include="    &lt;SparkleBlissContent Include=&quot;%24(MSBuildThisFileDirectory)..\content\bliss\**\*&quot; /&gt;" />
            <SparkleTargetsLines Include="  &lt;/ItemGroup&gt;" />
            <SparkleTargetsLines Include="  &lt;Target Name=&quot;CopySparkleBlissContent&quot; AfterTargets=&quot;Build&quot;&gt;" />
            <SparkleTargetsLines Include="    &lt;Copy SourceFiles=&quot;%40(SparkleBlissContent)&quot; DestinationFiles=&quot;%40(SparkleBlissContent-&gt;'%24(TargetDir)content\bliss\%25(RecursiveDir)%25(Filename)%25(Extension)')&quot; SkipUnchangedFiles=&quot;true&quot; /&gt;" />
            <SparkleTargetsLines Include="  &lt;/Target&gt;" />
            <SparkleTargetsLines Include="&lt;/Project&gt;" />
        </ItemGroup>

        <WriteLinesToFile File="$(SparkleTargets)"
                          Lines="@(SparkleTargetsLines)"
                          Overwrite="true" />

        <Delete Files="$(Nupkg)" />

        <ZipDirectory SourceDirectory="$(Tmp)"
                      DestinationFile="$(Nupkg)"
                      Overwrite="true" />

        <RemoveDir Directories="$(Tmp)" />
    </Target>
</Project>