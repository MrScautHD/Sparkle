<Project Sdk="Microsoft.NET.Sdk">
    
    <!-- Project -->
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <NoWarn>$(NoWarn);CS8618</NoWarn>
        <LangVersion>14</LangVersion>
    </PropertyGroup>
    
    <!-- Nuget -->
    <PropertyGroup>
        <Title>Sparkle</Title>
        <Authors>MrScautHD</Authors>
        <Version>5.1.6</Version>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);1591</NoWarn>
        <Description>A fast, Cross-platform .NET 10 C# 14 game engine.</Description>
        <PackageProjectUrl>https://mrscauthd.github.io/Sparkle/</PackageProjectUrl>
        <PackageLicenseUrl>https://github.com/MrScautHD/Sparkle/blob/main/LICENSE</PackageLicenseUrl>
        <RepositoryUrl>https://github.com/MrScautHD/Sparkle</RepositoryUrl>
        <PackageTags>Renderer, Game-Engine, Direct3D12, Vulkan, Metal, Net10, C#14, 2D, 3D, Fast, Physics, XNA, Cross-platform, Audio</PackageTags>
        <PackageIcon>icon.png</PackageIcon>
    </PropertyGroup>
    
    <!-- Libraries -->
    <ItemGroup>
        <PackageReference Include="Bliss" Version="1.6.8" GeneratePathProperty="true" />
        <PackageReference Include="HughPH.Box2D" Version="2026.5.5.222" />
        <PackageReference Include="Jitter2" Version="2.8.8" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />
    </ItemGroup>
    
    <!-- Icon -->
    <ItemGroup>
        <None Include="content\sparkle\images\icon.png" Pack="true" PackagePath="" />
    </ItemGroup>
    
    <!-- Pack Sparkle Content -->
    <ItemGroup>
        <Content Include="content\**\*"
                 Pack="true"
                 PackagePath="contentFiles\any\any\content\%(RecursiveDir)%(Filename)%(Extension)"
                 PackageCopyToOutput="true"
                 CopyToOutputDirectory="PreserveNewest"
                 BuildAction="None" />
    </ItemGroup>
    
    <!-- Pack Bliss Content -->
    <ItemGroup>
        <Content Include="$(PkgBliss)\content\content\bliss\**\*"
                 Pack="true"
                 PackagePath="contentFiles\any\any\content\bliss\%(RecursiveDir)%(Filename)%(Extension)"
                 PackageCopyToOutput="true"
                 CopyToOutputDirectory="PreserveNewest"
                 BuildAction="None"
                 Visible="false" />
    </ItemGroup>
</Project>